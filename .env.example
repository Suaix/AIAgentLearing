# ============================================================
# LearningPro — API Key 配置
# ============================================================
# 使用方法：
#   1. 复制此文件为 .env：
#      cp .env.example .env
#   2. 填写下方对应的 API Key（不需要全部填写，用到哪个填哪个）
#   3. 安全须知：
#      - .env 已被 .gitignore 排除，不会提交到 Git
#      - 不要在代码中硬编码 API Key
#      - 定期在 API 后台轮换 Key
# ============================================================

# ---------- DeepSeek API（当前主力） ----------
# 获取地址：https://platform.deepseek.com/api_keys
# 兼容方式：OpenAI SDK 兼容，设置 base_url 即可
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 使用方式：
#   from openai import OpenAI
#   client = OpenAI(api_key="...", base_url="https://api.deepseek.com")
#   response = client.chat.completions.create(
#       model="deepseek-v4-flash",  # 快速模型
#       # model="deepseek-v4-pro", # 高性能模型
#       messages=[{"role": "user", "content": "Hello"}]
#   )

# ---------- Anthropic API (Claude 系列) —【可选，后续】 ----------
# 获取地址：https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------- OpenAI API (GPT 系列) —【可选，后续】 ----------
# 获取地址：https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------- Google AI (Gemini 系列) —【可选，后续】 ----------
# 获取地址：https://aistudio.google.com/apikey
# GOOGLE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------- （可选）LangSmith — Agent 追踪与调试 ----------
# 获取地址：https://smith.langchain.com/settings
# LANGSMITH_API_KEY=ls__xxxxxxxxxxxxxxxxxxxxxxxxx
# LANGSMITH_PROJECT=LearningPro
